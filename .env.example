# 이 파일을 복사해서 .env 파일을 만드세요
# cp .env.example .env

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-여기에_실제_키_입력

# Google Sheets ID (URL에서 복사)
# https://docs.google.com/spreadsheets/d/[여기]/edit
GOOGLE_SHEETS_ID=여기에_시트_ID_입력

# Google Drive 루트 폴더 ID
# 폴더 URL 끝부분: https://drive.google.com/drive/folders/[여기]
GOOGLE_DRIVE_FOLDER_ID=여기에_폴더_ID_입력

# Google 서비스 계정 JSON (한 줄로)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# 선생님 이메일
TEACHER_EMAIL=연소사@gmail.com

# 토스페이먼츠 결제
# 테스트 키: https://developers.tosspayments.com/sandbox
TOSS_CLIENT_KEY=test_ck_여기에_클라이언트키
TOSS_SECRET_KEY=test_sk_여기에_시크릿키
